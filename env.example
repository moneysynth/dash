# ============================================
# MoneySynth - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================
# Google Analytics Configuration
# ============================================
# Get your Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
# Leave empty to disable Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ============================================
# Application Configuration
# ============================================
# Base URL for the application (used for canonical URLs, Open Graph, etc.)
# Production: https://moneysynth.com
# Development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Optional: Future Integrations
# ============================================
# Uncomment and configure when needed

# # AdSense Publisher ID (if using Google AdSense)
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=

# # Contact Form API (if using a contact form service)
# CONTACT_FORM_API_KEY=

# # Email Service (if sending emails)
# EMAIL_SERVICE_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@moneysynth.com

# # Database (if adding database features)
# DATABASE_URL=

# # Authentication (if adding user accounts)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# # Social Media API Keys (if adding social features)
# TWITTER_API_KEY=
# FACEBOOK_APP_ID=
